model Contract {
  id String @id @default(ulid())

  task   Task?   @relation(fields: [taskId], references: [id])
  taskId String? @unique @map("task_id")

  service   Service? @relation(fields: [serviceId], references: [id])
  serviceId String?  @map("service_id")

  client   User   @relation("client_contracts", fields: [clientId], references: [id])
  clientId String @map("client_id")

  contractor   User   @relation("contractor_contracts", fields: [contractorId], references: [id])
  contractorId String @map("contractor_id")

  status EnumContractStatus @default(SEND)

  amount Decimal

  clientAcceptedAt     DateTime? @map("client_accepted_at")
  contractorAcceptedAt DateTime? @map("contractor_accepted_at")

  commission Int

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@map("contracts")
}

enum EnumContractStatus {
  SEND
  IN_PROGRESS
  ON_HOLD
  DELIVERED
  COMPLETED
  REJECTED
}
