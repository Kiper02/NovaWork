model Chat {
  id String @id @default(ulid())

  title String
  type  EnumChatType

  context   EnumChatContext?
  contextId String?          @map("context_id")

  messages    Message[]
  chatMembers ChatMember[]

  isBlocked      Boolean   @default(false) @map("is_blocked")
  blockedAt      DateTime? @map("blocked_at")
  blockReason    String?   @map("block_reason")
  blockExpiresAt DateTime? @map("block_expires_at")

  blockedByUser   User?   @relation("blocked_chats", fields: [blockedByUserId], references: [id])
  blockedByUserId String? @map("blocked_by_user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@unique([context, contextId])
  @@map("chats")
}

enum EnumChatContext {
  CONTRACT
  BID
  WORKSPACE
}

enum EnumChatType {
  DIRECT
  GROUP
}
